# Praxis — Caddy block for /etc/caddy/Caddyfile on the deploy VPS.
#
# This file documents the Praxis-owned block of the host's Caddyfile.
# The host file is a composite: blocks for Colonize, Pirate-Battle, and
# Dashboard live in their own repos and are mirrored alongside this
# block at /etc/caddy/Caddyfile. See ADR-0004 for the multi-tenant
# context.
#
# Caddy manages TLS for all hostnames via its built-in ACME client; the
# global block (operator email, etc.) lives once at the top of the
# host's /etc/caddy/Caddyfile, not in this file.

praxis.blacksail.dev {
	# Upstream: praxis-web container on host port :3002.
	# (Colonize already uses :3000, Pirate-Battle uses :3001 — see the
	# port-allocation note in ADR-0004.)
	reverse_proxy 127.0.0.1:3002 {
		# Probe the web container's health endpoint every 30s; Caddy
		# stops sending traffic to an unhealthy upstream until it
		# recovers.
		health_uri /api/health
		health_interval 30s
		health_timeout 5s
		health_status 200
	}

	encode gzip zstd
}
